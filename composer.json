{
    "name": "yourvendor/http-errors",
    "description": "Beautiful, customizable HTTP error pages for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Yourvendor\\HttpErrors\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yourvendor\\HttpErrors\\HttpErrorsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}